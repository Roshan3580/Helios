# Helios free invited-beta placeholders (safe to commit).
#
# The invited beta runs the REAL product (WorkOS human auth + project API keys)
# on zero-cost infrastructure for a small set of invited testers. It is NOT an
# SLA-backed production service. See docs/FREE_BETA_DEPLOYMENT.md.
#
# Topology (all free / already-provisioned):
#   - Frontend:  existing Vercel `helios-staging` project (helios-staging-tau.vercel.app)
#   - Auth:      WorkOS Staging environment (invited testers)
#   - Backend:   NEW Render Free web service `helios-api-beta` from branch main
#   - Database:  ONE external free PostgreSQL (e.g. Neon free tier)
#
# NEVER put real secrets in this file. Names + safe placeholders only. Secrets
# are entered directly in the Vercel and Render dashboards.

# =============================================================================
# Shared environment identity
# =============================================================================
# Beta reuses the hardened "staging" contract (fail-closed: demo + e2e forbidden).
HELIOS_ENVIRONMENT=staging
HELIOS_E2E_TEST_MODE=false

# =============================================================================
# Frontend (Vercel `helios-staging`) — browser-public (VITE_* = non-secrets only)
# =============================================================================
VITE_API_BASE_URL=https://helios-api-beta.onrender.com
VITE_HELIOS_ENVIRONMENT=staging
VITE_HELIOS_DEMO_MODE=false
VITE_HELIOS_E2E_TEST_MODE=false

# =============================================================================
# Frontend (Vercel) — server-only WorkOS AuthKit (NEVER VITE_*)
# Set these in the Vercel dashboard, not in any committed file.
# =============================================================================
# WORKOS_CLIENT_ID=<staging client id>   # MUST equal the backend WORKOS_CLIENT_ID
# WORKOS_API_KEY=<server-only staging API key>
# WORKOS_REDIRECT_URI=https://helios-staging-tau.vercel.app/api/auth/callback
# WORKOS_COOKIE_PASSWORD=<random secret, at least 32 characters>
# Session cookie is SameSite=Lax + Secure + HttpOnly + Path=/ by AuthKit
# default (Secure inferred from the HTTPS redirect URI). There is no
# WORKOS_COOKIE_SAMESITE env var; do not set one.

# Forbidden in the beta (staging contract rejects these):
# HELIOS_E2E_ACCESS_TOKEN=
# HELIOS_E2E_ORG_ID=

# =============================================================================
# Backend (Render Free `helios-api-beta`) — server-only
# Set secrets in the Render dashboard, not in any committed file.
# =============================================================================
PYTHON_VERSION=3.12.8
HELIOS_ENVIRONMENT=staging
HELIOS_DEMO_MODE=false
HELIOS_E2E_TEST_MODE=false
HELIOS_ANALYST_NARRATIVE_ENABLED=false
HELIOS_ANALYST_ALLOW_THIRD_PARTY=false
# DATABASE_URL=<external PostgreSQL URL>
# Exact single origin — no wildcard, no loopback, HTTPS only.
CORS_ORIGINS=https://helios-staging-tau.vercel.app
# WORKOS_CLIENT_ID=<same staging client id as the frontend>   # parity is required
# WORKOS_ISSUER and WORKOS_JWKS_URL are DERIVED from WORKOS_CLIENT_ID and are
# usually left unset. If set explicitly they must match the official WorkOS
# contract exactly, or every access token is rejected (401) even though the
# user is signed in:
#   WORKOS_ISSUER=https://api.workos.com                 (the AuthKit issuer; API root)
#   WORKOS_JWKS_URL=https://api.workos.com/sso/jwks/<client id>
# The access-token issuer is the API root — NOT /user_management/<client id>.
# Set WORKOS_ISSUER explicitly only for a custom WorkOS auth domain (HTTPS).
# The backend fails closed at startup if these resolve to a non-WorkOS contract.
# OPENAI_API_KEY=   # leave unset — narrative stays disabled in the beta
