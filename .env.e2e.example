# Helios browser E2E environment example
#
# Used by scripts/run-e2e.sh. Do not copy into production. Do not commit real
# JWTs or project API keys. Values below are placeholders only.

# Explicit test mode (required). Rejected when NODE_ENV=production.
HELIOS_E2E_TEST_MODE=true

# Client boolean only — never put tokens in VITE_* variables.
VITE_HELIOS_E2E_TEST_MODE=true

# Runtime-minted by the harness (ephemeral RSA + loopback JWKS). Not committed.
# HELIOS_E2E_ACCESS_TOKEN=
# HELIOS_E2E_ORG_ID=org_01E2EORG00000000000000001
# HELIOS_E2E_USER_ID=user_01E2EUSER000000000000001
# HELIOS_E2E_USER_EMAIL=e2e@helios.test

# Loopback issuer/JWKS (harness starts an ephemeral server).
# WORKOS_ISSUER=http://127.0.0.1:<port>/
# WORKOS_JWKS_URL=http://127.0.0.1:<port>/jwks

# Isolated test database (docker-compose.test.yml).
# DATABASE_URL=postgresql://helios_test:helios_test@localhost:5434/helios_test

# Narrative / providers must stay off for the release gate.
# OPENAI_API_KEY=
# HELIOS_NARRATIVE_ENABLED=false
