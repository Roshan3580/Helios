# Helios environment configuration
# Copy to .env for local development.
# For production, set these in Render (backend) and Vercel (frontend) — see docs/DEPLOYMENT.md

# =============================================================================
# Frontend (Vercel — build-time variables)
# VITE_* are embedded at build time; changing them requires a Vercel redeploy.
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000
# Production example:
# VITE_API_BASE_URL=https://<backend-url>

# Demo mode: true = always use static in-app demo data (no API calls)
#            false = fetch live API; fall back to demo data if API unreachable
VITE_HELIOS_DEMO_MODE=true
# Production live demo:
# VITE_HELIOS_DEMO_MODE=false

# =============================================================================
# Backend (Render — runtime variables)
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://helios:helios@localhost:5433/helios
# Production examples (Neon/Supabase may require sslmode):
# DATABASE_URL=postgresql://user:pass@dpg-xxx.render.com/helios_xxxx
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres?sslmode=require

# Comma-separated browser origins allowed to call the API (CORS)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ORIGINS=https://<frontend-url>

# When true, POST /v1/demo/seed is enabled. Set false after initial production seed.
HELIOS_DEMO_MODE=true

# Optional — uvicorn bind (Dockerfile uses 0.0.0.0 and $PORT from the platform)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
