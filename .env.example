# Helios environment configuration
# Copy to .env and adjust for local development

# --- Frontend ---
# Set VITE_HELIOS_DEMO_MODE=false to load traces from the backend API.
VITE_API_BASE_URL=http://localhost:8000
VITE_HELIOS_DEMO_MODE=true

# --- Backend ---
DATABASE_URL=postgresql://helios:helios@localhost:5433/helios
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
HELIOS_DEMO_MODE=true
