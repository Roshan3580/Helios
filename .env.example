# Helios environment configuration
# Copy to .env for local development.
# For production, set these in Render (backend) and Vercel (frontend): see docs/DEPLOYMENT.md

# =============================================================================
# Frontend (Vercel: build-time variables)
# VITE_* are embedded at build time; changing them requires a Vercel redeploy.
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000
# Production example:
# VITE_API_BASE_URL=https://<backend-url>

# Demo mode: true = always use static in-app demo data (no API calls)
#            false = fetch live API; fall back to demo data if API unreachable
VITE_HELIOS_DEMO_MODE=true
# Production live demo:
# VITE_HELIOS_DEMO_MODE=false

# =============================================================================
# TanStack Start server (runtime, server-only — NEVER use VITE_* for these)
# WorkOS AuthKit human authentication; see docs/ADR_004_WORKOS_HUMAN_AUTH.md.
# Placeholders only — copy real development credentials from the WorkOS
# dashboard into your local .env; never commit them.
# =============================================================================

# WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx
# WORKOS_API_KEY=sk_test_xxxxxxxxxxxxx
# WORKOS_REDIRECT_URI=http://localhost:5173/api/auth/callback
# WORKOS_COOKIE_PASSWORD=<random string, at least 32 characters>

# =============================================================================
# Backend (Render: runtime variables)
# =============================================================================

# FastAPI verification of WorkOS access tokens (no WorkOS API key needed).
# Issuer/JWKS URL derive from the client ID when unset.
# WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx
# WORKOS_ISSUER=
# WORKOS_JWKS_URL=
# WORKOS_JWKS_CACHE_TTL=3600

# PostgreSQL connection string
DATABASE_URL=postgresql://helios:helios@localhost:5433/helios
# Production examples (Neon/Supabase may require sslmode):
# DATABASE_URL=postgresql://user:pass@dpg-xxx.render.com/helios_xxxx
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres?sslmode=require

# Comma-separated browser origins allowed to call the API (CORS)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ORIGINS=https://<frontend-url>

# When true, POST /v1/demo/seed is enabled. Set false after initial production seed.
HELIOS_DEMO_MODE=true

# Optional: uvicorn bind (Dockerfile uses 0.0.0.0 and $PORT from the platform)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# =============================================================================
# Optional analyst narrative (server-only — NEVER VITE_*)
# Disabled by default. Both enablement flags must be true AND provider/model/
# key must be set before any third-party call is made. See ADR 005.
# =============================================================================

# HELIOS_ANALYST_NARRATIVE_ENABLED=false
# HELIOS_ANALYST_ALLOW_THIRD_PARTY=false
# HELIOS_ANALYST_PROVIDER=openai
# HELIOS_ANALYST_MODEL=gpt-4o-mini
# HELIOS_ANALYST_TIMEOUT_SECONDS=20
# HELIOS_ANALYST_MAX_OUTPUT_TOKENS=1200
# HELIOS_ANALYST_MAX_EVIDENCE_BYTES=24000
# HELIOS_ANALYST_MAX_FINDINGS=25
# OPENAI_API_KEY=
