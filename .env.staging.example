# Helios staging environment placeholders (safe to commit).
# Replace example hostnames with the fixed staging URLs assigned by Vercel/Render.
# NEVER put real secrets in this file. See docs/STAGING_DEPLOYMENT.md and
# docs/DEPLOYMENT_ENVIRONMENT_MATRIX.md.

# =============================================================================
# Shared environment identity
# =============================================================================
HELIOS_ENVIRONMENT=staging
HELIOS_E2E_TEST_MODE=false

# =============================================================================
# Frontend (Vercel) — browser-public (VITE_* only for non-secrets)
# =============================================================================
VITE_API_BASE_URL=https://helios-api-staging.example.onrender.com
VITE_HELIOS_DEMO_MODE=false
VITE_HELIOS_ENVIRONMENT=staging
VITE_HELIOS_E2E_TEST_MODE=false

# =============================================================================
# Frontend (Vercel) — server-only WorkOS AuthKit (NEVER VITE_*)
# =============================================================================
# WORKOS_CLIENT_ID=client_staging_xxxxxxxx
# WORKOS_API_KEY=sk_test_xxxxxxxx
# WORKOS_REDIRECT_URI=https://helios-staging.example.vercel.app/api/auth/callback
# WORKOS_COOKIE_PASSWORD=<random string, at least 32 characters>
# WORKOS_COOKIE_SAMESITE=lax
# Optional:
# WORKOS_COOKIE_NAME=wos-session
# WORKOS_COOKIE_MAX_AGE=34560000

# Forbidden in staging/production:
# HELIOS_E2E_ACCESS_TOKEN=
# HELIOS_E2E_ORG_ID=

# =============================================================================
# Backend (Render) — server-only
# =============================================================================
# DATABASE_URL=<Render Internal Database URL for helios_staging>
# CORS_ORIGINS=https://helios-staging.example.vercel.app
# WORKOS_CLIENT_ID=client_staging_xxxxxxxx
# WORKOS_ISSUER=https://api.workos.com/user_management/client_staging_xxxxxxxx
# WORKOS_JWKS_URL=https://api.workos.com/sso/jwks/client_staging_xxxxxxxx
HELIOS_DEMO_MODE=false
HELIOS_ANALYST_NARRATIVE_ENABLED=false
HELIOS_ANALYST_ALLOW_THIRD_PARTY=false
# OPENAI_API_KEY=   # leave unset while narrative is disabled

# =============================================================================
# Smoke script inputs (operator shell only — not platform env)
# =============================================================================
# HELIOS_STAGING_FRONTEND_URL=https://helios-staging.example.vercel.app
# HELIOS_STAGING_API_URL=https://helios-api-staging.example.onrender.com
# HELIOS_STAGING_PROJECT_KEY=   # optional machine check; never commit
